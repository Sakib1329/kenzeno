<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Kenzeno</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>kenzeno</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- Launch screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <!-- Supported orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Performance & input improvements -->
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!-- === Required Permissions (Privacy Descriptions) === -->

    <!-- Camera (for body scan, custom workout videos, etc.) -->
    <key>NSCameraUsageDescription</key>
    <string>Kenzeno needs access to your camera for body scanning, workout recording, and live fitness tracking.</string>

    <!-- Photo Library (image_picker for profile photo, nutrition photos, etc.) -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Kenzeno needs access to your photo library to let you upload profile pictures, progress photos, or nutrition images.</string>

    <!-- Photo Library Add-Only (if only writing/saving is needed) -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Kenzeno needs to save photos to your library (e.g., progress screenshots or workout summaries).</string>

    <!-- Microphone (for potential voice input or video recording audio) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Kenzeno may need microphone access for video recording during workouts or voice commands.</string>

    <!-- Notifications (firebase_messaging + flutter_local_notifications) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>remote-notification</string>
    </array>
    <key>NSUserNotificationsUsageDescription</key>
    <string>Kenzeno would like to send you reminders, progress updates, and motivational notifications.</string>

    <!-- Optional: Motion & Fitness (if using HealthKit or motion sensors later) -->
    <!-- <key>NSMotionUsageDescription</key> -->
    <!-- <string>Kenzeno uses motion data to track workouts and activity more accurately.</string> -->

</dict>
</plist>